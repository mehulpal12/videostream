generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  clerkId       String    @unique
  email         String    @unique
  username      String?   @unique
  firstName     String?
  lastName      String?
  imageUrl      String?
  role          String    @default("STUDENT") // Added to distinguish teachers

  // Relations
  enrollments   Enrollment[]
  progress      UserProgress[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([clerkId])
  @@index([email])
}

model Course {
  id          String   @id @default(cuid())
  userId      String
  title       String
  mentor      String
  description String?  @db.Text
  price       Float
  badge       String?
  color       String   @default("bg-blue-600")
  isPublished Boolean  @default(false)

  // Systematic Hierarchy
  sections    Section[]
  enrollments Enrollment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Section {
  id        String   @id @default(cuid())
  title     String
  order     Int      // To keep sections systematic (1, 2, 3...)
  
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  lectures  Lecture[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lecture {
  id             String   @id @default(cuid())
  title          String
  videoUrl       String   // Cloudinary URL
  publicId       String   // Cloudinary ID for management
  duration       Float
  order          Int      // Position within the section
  isPreview      Boolean  @default(false)

  sectionId      String
  section        Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  
  userProgress   UserProgress[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  @@unique([userId, courseId])
}

model UserProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  lectureId   String
  lecture     Lecture  @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  
  isCompleted Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([userId, lectureId])
} 